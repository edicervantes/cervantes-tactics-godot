[resource]
script = ExtResource("1")
chapter_name = "Capitulo I: La Puerta De La Sierra"
objective_text = "Protege el cristal familiar hasta derrotar a la Orden Sin Memoria."
objective_short = "Protege el cristal"
victory_condition = "Victoria: derrota a todos los enemigos."
defeat_condition = "Derrota: el cristal se rompe o cae toda la familia."
tactical_hint = "Manten a Erick y Hercules cerca del cristal, usa a Mitzi y Diego para cortar rutas antes de que la Orden llegue al centro."
opening_tutorial = "Selecciona una unidad. Una accion por personaje. WASD/flechas mueven camara; C recentra."
move_tutorial = "Mover: elige una casilla iluminada. La ruta clara muestra el costo."
attack_tutorial = "Atacar: las casillas doradas marcan rango. Erick remata cerca; Mitzi presiona lejos y protege con evasion."
special_tutorial = "Especial: Diego usa magia. Hercules cura a un aliado adyacente herido. Erick libera Corte del Aguila cuando LIM llega a 3/3."
defend_tutorial = "Defender: reduce el proximo dano. Bueno para cerrar paso al cristal."
wait_tutorial = "Esperar: conserva posicion y termina la accion."
enemy_turn_tutorial = "Rojo marca amenaza enemiga. Mira la ruta antes de tu siguiente ronda."
player_turn_tutorial = "Nueva ronda: bloquea rutas, remata heridos y protege el centro."
grid_size = Vector2i(12, 9)
crystal_grid = Vector2i(6, 4)
crystal_hp = 5
