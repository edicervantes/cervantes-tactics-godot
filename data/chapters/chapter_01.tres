intro_lines = Array[Dictionary]([{
"speaker": "Erick",
"text": "La Orden esta atacando el cristal. Si lo tocan, este recuerdo empieza a romperse."
}, {
"speaker": "Mitzi",
"text": "No tenemos que ganar una guerra hoy. Solo proteger lo que nos recuerda quienes somos."
}, {
"speaker": "Diego",
"text": "Entonces que vengan. Yo cuido la luz roja."
}, {
"speaker": "Hercules",
"text": "Hercules se planta frente al cristal. Nadie pasa sin pedir permiso."
}, {
"speaker": "Tuffy",
"text": "Piensen en rondas: primero cierren caminos, despues castiguen a quien se acerque demasiado."
}])
enemy_turn_lines = Array[Dictionary]([{
"speaker": "Tuffy",
"text": "Miren sus pasos. La Orden no ataca improvisadamente, pero si cambia de ruta cuando la bloquean."
}])
first_enemy_defeated_lines = Array[Dictionary]([{
"speaker": "Mitzi",
"text": "Uno menos. No perdamos el centro; el cristal sigue llamandolos."
}])
first_player_hurt_lines = Array[Dictionary]([{
"speaker": "Hercules",
"text": "Respira. Mientras sigamos juntos, este recuerdo no se rompe."
}])
crystal_low_hp_lines = Array[Dictionary]([{
"speaker": "Diego",
"text": "La luz esta fallando. Si el cristal recibe otro golpe, nos quedamos sin margen."
}])
first_level_up_lines = Array[Dictionary]([{
"speaker": "Tuffy",
"text": "La memoria responde. Cuando la cuidan, tambien los fortalece."
}])
hidden_path_revealed_lines = Array[Dictionary]([{
"speaker": "Tuffy",
"text": "Hay caminos que no se pisan hasta que alguien los recuerda."
}])
outro_win_lines = Array[Dictionary]([{
"speaker": "Erick",
"text": "El cristal sigue entero. La memoria familiar aguanto su primera prueba."
}, {
"speaker": "Tuffy",
"text": "Un recuerdo cuidado con amor siempre encuentra el camino de vuelta."
}])
outro_lose_lines = Array[Dictionary]([{
"speaker": "Erick",
"text": "La Orden alcanzo el cristal. Tenemos que volver a intentarlo antes de que el recuerdo se apague."
}])
